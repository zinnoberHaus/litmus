{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://litmus-data.dev/schemas/v1/check-suite.schema.json",
  "title": "Litmus check report (v1)",
  "description": "Frozen v1 contract for the output of `litmus check --format json`. Any CI integration (Slack bot, dashboard scraper, PagerDuty webhook) that reads this JSON depends on this shape. Breaking changes require a major-version bump and a migration window.",
  "type": "object",
  "required": ["litmus_version", "schema_version", "generated_at", "metrics", "summary"],
  "additionalProperties": true,
  "properties": {
    "litmus_version": {
      "type": "string",
      "description": "Version of the Litmus package that produced the report (e.g. '0.1.0')."
    },
    "schema_version": {
      "type": "string",
      "const": "v1",
      "description": "Version of the JSON contract. Always 'v1' for this schema."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp of when the report was produced."
    },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "summary": {
      "type": "object",
      "required": ["total", "healthy", "warning", "failing"],
      "additionalProperties": false,
      "properties": {
        "total":   { "type": "integer", "minimum": 0 },
        "healthy": { "type": "integer", "minimum": 0 },
        "warning": { "type": "integer", "minimum": 0 },
        "failing": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["name", "trust_score", "trust_total", "checks"],
      "additionalProperties": true,
      "properties": {
        "name":         { "type": "string", "minLength": 1 },
        "description":  { "type": ["string", "null"] },
        "owner":        { "type": ["string", "null"] },
        "tags":         { "type": "array", "items": { "type": "string" } },
        "sources":      { "type": "array", "items": { "type": "string" } },
        "trust_score":  { "type": "number", "minimum": 0 },
        "trust_total":  { "type": "integer", "minimum": 0 },
        "checks":       { "type": "array", "items": { "$ref": "#/$defs/check" } }
      }
    },
    "check": {
      "type": "object",
      "required": ["name", "status", "message"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable rule name (e.g. 'Freshness', 'Null rate on amount')."
        },
        "status": {
          "type": "string",
          "enum": ["passed", "warning", "failed", "error"],
          "description": "Outcome of this check. 'error' means the connector itself threw."
        },
        "message": { "type": "string" },
        "actual_value": {
          "description": "Measured value. Type varies by rule (number, string, datetime ISO, or null).",
          "type": ["number", "string", "integer", "boolean", "null"]
        },
        "threshold": {
          "description": "Configured threshold this check was evaluated against.",
          "type": ["number", "string", "integer", "boolean", "null"]
        }
      }
    }
  }
}
