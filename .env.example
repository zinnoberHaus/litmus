# DataPilot environment variables
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# Anything left blank is optional — DataPilot will run without it, but the
# corresponding integration will be disabled.

# ── Warehouse (defaults to local DuckDB if unset) ──────────────────────────
# LITMUS_WAREHOUSE_URL=duckdb:///./data/warehouse.duckdb
# LITMUS_WAREHOUSE_URL=postgresql://user:pass@host:5432/db
# LITMUS_WAREHOUSE_URL=snowflake://user@account/db/schema?warehouse=wh
# LITMUS_WAREHOUSE_USER=
# LITMUS_WAREHOUSE_PASSWORD=

# ── Notion (project docs + playbook) ───────────────────────────────────────
# Get yours: https://www.notion.so/profile/integrations
# Share your target page/database with the integration after creating it.
NOTION_API_KEY=

# ── Linear (issues + bugs) ─────────────────────────────────────────────────
# Get yours: https://linear.app/settings/api
LINEAR_API_KEY=

# ── Anthropic (powers AI run explanations + the agent team) ────────────────
# Get yours: https://console.anthropic.com/settings/keys
# Reuses LITMUS_ANTHROPIC_API_KEY for backwards-compat with the trust engine.
LITMUS_ANTHROPIC_API_KEY=
# Or use the more conventional name; either is read:
# ANTHROPIC_API_KEY=

# ── Slack (optional — weekly review summary + trust regression alerts) ─────
# Webhook URL from a Slack incoming-webhook app:
LITMUS_SLACK_WEBHOOK_URL=
# Default channel for ops-pilot to post to:
LITMUS_SLACK_DEFAULT_CHANNEL=#data

# ── GitHub webhook (optional — auto-ingest .metric file changes) ───────────
# LITMUS_GITHUB_WEBHOOK_SECRET=

# ── Litmus history store (optional — defaults to ~/.litmus/history.db) ─────
# LITMUS_HISTORY_DB=./data/litmus_history.db
